<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LabSystem Pro | Dashboard</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    :root { --main: #1e293b; --accent: #2563eb; --success: #059669; --danger: #dc2626; --warning: #d97706; --bg: #f1f5f9; --sidebar-width: 260px; }
    body { display: flex; font-family: 'Segoe UI', system-ui; margin: 0; background: var(--bg); color: #334155; min-height: 100vh; }
    
    /* SIDEBAR */
    nav { width: var(--sidebar-width); background: var(--main); color: white; height: 100vh; padding: 20px; position: fixed; display: flex; flex-direction: column; box-sizing: border-box; }
    nav h2 { color: #60a5fa; text-align: center; border-bottom: 1px solid #334155; padding-bottom: 15px; }
    nav ul { list-style: none; padding: 0; flex-grow: 1; }
    nav li { padding: 12px; cursor: pointer; border-radius: 8px; margin-bottom: 5px; transition: 0.3s; display: flex; align-items: center; gap: 10px; }
    nav li:hover { background: #334155; }
    nav li.active { background: var(--accent); box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3); }

    /* CONTENIDO */
    main { margin-left: var(--sidebar-width); padding: 40px; width: calc(100% - var(--sidebar-width)); box-sizing: border-box; }
    .header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
    .search-box { position: relative; width: 300px; }
    .search-box input { width: 100%; padding: 10px 10px 10px 35px; border-radius: 8px; border: 1px solid #cbd5e1; outline: none; }
    .search-box i { position: absolute; left: 12px; top: 12px; color: #94a3b8; }

    .card { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); margin-bottom: 25px; }
    
    /* BOTONES */
    .btn { padding: 10px 18px; border: none; border-radius: 8px; cursor: pointer; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; transition: 0.2s; }
    .btn-new { background: var(--success); color: white; }
    .btn-refresh { background: #64748b; color: white; }

    /* FORMULARIO */
    #form-section { display: none; border: 2px solid var(--accent); animation: slideDown 0.3s ease; }
    .grid-inputs { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 20px; }
    .input-group { display: flex; flex-direction: column; gap: 5px; }
    input, select { padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; }

    /* TABLA */
    table { width: 100%; border-collapse: collapse; }
    th { text-align: left; padding: 12px; background: #f8fafc; border-bottom: 2px solid #e2e8f0; font-size: 0.8rem; color: #64748b; text-transform: uppercase; }
    td { padding: 12px; border-bottom: 1px solid #f1f5f9; font-size: 0.9rem; }
    .stock-warning { background-color: #fef2f2; color: #dc2626; font-weight: bold; }
    @keyframes slideDown { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
  </style>
</head>
<body>

  <nav>
    <h2><i class="fas fa-microscope"></i> LAB-PRO</h2>
    <ul id="menu-items">
      <li id="li-pacientes" class="active" onclick="switchModulo('pacientes')"><i class="fas fa-user-injured"></i> Pacientes</li>
      <li id="li-medicos" onclick="switchModulo('medicos')"><i class="fas fa-user-md"></i> Médicos</li>
      <li id="li-insumos" onclick="switchModulo('insumos')"><i class="fas fa-box"></i> Insumos</li>
      <li id="li-citas" onclick="switchModulo('citas')"><i class="fas fa-calendar-alt"></i> Citas</li>
      <li id="li-facturas" onclick="switchModulo('facturas')"><i class="fas fa-file-invoice-dollar"></i> Facturas</li>
      <li id="li-equipos" onclick="switchModulo('equipos')"><i class="fas fa-tools"></i> Equipos</li>
      <li id="li-examenes" onclick="switchModulo('examenes')"><i class="fas fa-vials"></i> Exámenes</li>
      <li id="li-resultados" onclick="switchModulo('resultados')"><i class="fas fa-clipboard-check"></i> Resultados</li>
      <li id="li-usuarios" onclick="switchModulo('usuarios')"><i class="fas fa-users-cog"></i> Usuarios</li>
    </ul>
    <button onclick="logout()" style="background:none; border:none; color:#f87171; cursor:pointer; padding:10px; text-align:left;"><i class="fas fa-sign-out-alt"></i> Cerrar Sesión</button>
  </nav>

  <main>
    <div class="header-flex">
      <div>
        <h1 id="page-title">Pacientes</h1>
        <small id="user-tag" style="color: var(--accent); font-weight: bold;"></small>
      </div>
      <div style="display: flex; gap: 10px;">
        <div class="search-box">
          <i class="fas fa-search"></i>
          <input type="text" id="search" placeholder="Buscar..." onkeyup="filtrar()">
        </div>
        <button class="btn btn-new" onclick="abrirFormulario()"><i class="fas fa-plus"></i> Nuevo</button>
        <button class="btn btn-refresh" onclick="cargarDatos()"><i class="fas fa-sync"></i></button>
      </div>
    </div>

    <div id="form-section" class="card">
      <h3 id="form-title">Nuevo Registro</h3>
      <form id="crud-form">
        <div id="dynamic-inputs" class="grid-inputs"></div>
        <div style="text-align: right; gap: 10px; display: flex; justify-content: flex-end;">
          <button type="button" class="btn" style="background:#e2e8f0" onclick="cerrarFormulario()">Cancelar</button>
          <button type="submit" class="btn btn-new">Guardar</button>
        </div>
      </form>
    </div>

    <div class="card">
      <table>
        <thead id="thead"></thead>
        <tbody id="tbody"></tbody>
      </table>
    </div>
  </main>

  <script>
    let modActual = 'pacientes';
    let editId = null;
    const token = localStorage.getItem('token');
    const user = JSON.parse(localStorage.getItem('user'));

    if (!token) window.location.href = '/login';

    const esquemas = {
      pacientes: { labels:['Nombre','CI','Telf'], keys:['nombre','ci','telefono'], inputs:[{n:'nombre',l:'Nombre'},{n:'ci',l:'CI'},{n:'telefono',l:'Telf'}] },
      medicos: { labels:['Dr','Especialidad','MPPS'], keys:['nombre','especialidad','mpps'], inputs:[{n:'nombre',l:'Nombre'},{n:'especialidad',l:'Especialidad'},{n:'mpps',l:'MPPS'}] },
      insumos: { labels:['Insumo','Stock','Unidad'], keys:['nombre','stock','unidad'], inputs:[{n:'nombre',l:'Nombre'},{n:'stock',l:'Stock',t:'number'},{n:'unidad',l:'Unidad',t:'select',o:['Unidades','ML','Cajas']}] },
      citas: { labels:['Paciente','Fecha','Estado'], keys:['pacienteId','fecha','estado'], inputs:[{n:'pacienteId',l:'Paciente',t:'select',ref:'pacientes'},{n:'fecha',l:'Fecha',t:'date'},{n:'estado',l:'Estado',t:'select',o:['Pendiente','Completada']}] },
      facturas: { labels:['Paciente','Monto','Pagado'], keys:['pacienteId','montoTotal','pagado'], inputs:[{n:'pacienteId',l:'Paciente',t:'select',ref:'pacientes'},{n:'montoTotal',l:'Monto',t:'number'},{n:'pagado',l:'Pagado',t:'select',o:['true','false']}] },
      equipos: { labels:['Equipo','Marca','Estado'], keys:['nombre','marca','estado'], inputs:[{n:'nombre',l:'Nombre'},{n:'marca',l:'Marca'},{n:'estado',l:'Estado',t:'select',o:['Operativo','En Reparacion']}] },
      examenes: { labels:['Examen','Precio','Orden'], keys:['nombre','precio','numeroOrden'], inputs:[{n:'nombre',l:'Nombre'},{n:'precio',l:'Precio',t:'number'},{n:'numeroOrden',l:'N° Orden'}] },
      resultados: { labels:['Paciente','Valor','Orden'], keys:['pacienteId','valor','numeroOrden'], inputs:[{n:'pacienteId',l:'Paciente',t:'select',ref:'pacientes'},{n:'valor',l:'Valor'},{n:'numeroOrden',l:'N° Orden'}] },
      usuarios: { labels:['Username','Rol','Cargo'], keys:['username','rol','cargo'], inputs:[{n:'username',l:'User'},{n:'rol',l:'Rol',t:'select',o:['Admin','Recepcion','Bioanalista','Contador']},{n:'cargo',l:'Cargo'},{n:'password',l:'Password',t:'password'}] }
    };

    window.onload = () => {
      document.getElementById('user-tag').innerText = `${user.username} | ${user.rol}`;
      configurarPermisos(user.rol);
      cargarDatos();
    };

    function configurarPermisos(rol) {
      const perms = {
        'Admin': ['pacientes','medicos','insumos','citas','facturas','equipos','examenes','resultados','usuarios'],
        'Recepcion': ['pacientes','medicos','citas'],
        'Bioanalista': ['pacientes','insumos','equipos','resultados','examenes'],
        'Contador': ['pacientes','facturas']
      };
      document.querySelectorAll('#menu-items li').forEach(li => {
        const id = li.id.replace('li-','');
        li.style.display = perms[rol].includes(id) ? 'flex' : 'none';
      });
    }

    async function cargarDatos() {
      const config = esquemas[modActual];
      document.getElementById('thead').innerHTML = `<tr>${config.labels.map(l=>`<th>${l}</th>`).join('')}<th>Acciones</th></tr>`;
      
      const res = await fetch(`/api/${modActual}`, { headers: {'Authorization': `Bearer ${token}`} });
      const data = await res.json();
      
      document.getElementById('tbody').innerHTML = data.map(item => {
        let alertClass = (modActual === 'insumos' && item.stock < 10) ? 'stock-warning' : '';
        return `<tr class="${alertClass}">
          ${config.keys.map(k => {
            let v = item[k];
            if(v && typeof v === 'object') v = v.nombre || v._id;
            if(k === 'fecha') v = new Date(v).toLocaleDateString();
            return `<td>${v || '-'}</td>`;
          }).join('')}
          <td><button onclick="eliminar('${item._id}')" style="color:red; border:none; background:none; cursor:pointer;"><i class="fas fa-trash"></i></button></td>
        </tr>`;
      }).join('');
    }

    async function abrirFormulario() {
      const config = esquemas[modActual];
      let html = '';
      for (let i of config.inputs) {
        if (i.t === 'select') {
          let opts = i.o || [];
          if (i.ref) {
            const r = await fetch(`/api/${i.ref}`, { headers: {'Authorization':`Bearer ${token}`} });
            const d = await r.json();
            opts = d.map(x => x.nombre || x.username);
          }
          html += `<div class="input-group"><label>${i.l}</label><select id="in-${i.n}">${opts.map(o=>`<option value="${o}">${o}</option>`)}</select></div>`;
        } else {
          html += `<div class="input-group"><label>${i.l}</label><input type="${i.t || 'text'}" id="in-${i.n}"></div>`;
        }
      }
      document.getElementById('dynamic-inputs').innerHTML = html;
      document.getElementById('form-section').style.display = 'block';
    }

    document.getElementById('crud-form').onsubmit = async (e) => {
      e.preventDefault();
      const body = {};
      esquemas[modActual].inputs.forEach(i => body[i.n] = document.getElementById(`in-${i.n}`).value);
      
      await fetch(`/api/${modActual}`, {
        method: 'POST',
        headers: {'Content-Type':'application/json', 'Authorization':`Bearer ${token}`},
        body: JSON.stringify(body)
      });
      cerrarFormulario();
      cargarDatos();
    };

    function switchModulo(m) {
      modActual = m;
      document.querySelectorAll('nav li').forEach(li => li.classList.remove('active'));
      document.getElementById(`li-${m}`).classList.add('active');
      document.getElementById('page-title').innerText = m.charAt(0).toUpperCase() + m.slice(1);
      cargarDatos();
    }

    function filtrar() {
      const val = document.getElementById('search').value.toLowerCase();
      document.querySelectorAll('#tbody tr').forEach(tr => {
        tr.style.display = tr.innerText.toLowerCase().includes(val) ? '' : 'none';
      });
    }

    function cerrarFormulario() { document.getElementById('form-section').style.display = 'none'; }
    function logout() { localStorage.clear(); window.location.href = '/login'; }
  </script>
</body>
</html>