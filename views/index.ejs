<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LabSystem Pro | Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --main: #1e293b; --accent: #2563eb; --bg: #f1f5f9; --sidebar-width: 260px; }
        body { display: flex; font-family: 'Segoe UI', sans-serif; margin: 0; background: var(--bg); }
        
        /* Estilos de la interfaz */
        nav { width: var(--sidebar-width); background: var(--main); color: white; height: 100vh; position: fixed; padding: 20px; box-sizing: border-box; }
        main { margin-left: var(--sidebar-width); flex-grow: 1; padding: 30px; }
        .card { background: white; padding: 20px; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th { text-align: left; padding: 12px; border-bottom: 2px solid #e2e8f0; color: #64748b; }
        td { padding: 12px; border-bottom: 1px solid #e2e8f0; }
        
        .btn-logout { margin-top: auto; cursor: pointer; color: #fb7185; font-weight: bold; }
        .error-msg { color: #dc2626; text-align: center; padding: 20px; display: none; }
    </style>
</head>
<body>

<nav>
    <h2>LabSystem</h2>
    <hr>
    <ul style="list-style: none; padding: 0;">
        <li onclick="switchModulo('pacientes')" style="cursor:pointer; padding:10px 0;"> <i class="fas fa-user-injured"></i> Pacientes</li>
        <li onclick="switchModulo('examenes')" style="cursor:pointer; padding:10px 0;"> <i class="fas fa-vials"></i> Exámenes</li>
        <li onclick="switchModulo('resultados')" style="cursor:pointer; padding:10px 0;"> <i class="fas fa-file-medical"></i> Resultados</li>
    </ul>
    <div class="btn-logout" onclick="logout()"> <i class="fas fa-sign-out-alt"></i> Cerrar Sesión</div>
</nav>

<main>
    <header style="display: flex; justify-content: space-between; align-items: center;">
        <h1 id="page-title">Panel de Control</h1>
        <div id="user-info" style="font-weight: bold; color: var(--accent);"></div>
    </header>

    <div class="card">
        <div id="error-container" class="error-msg"></div>
        <table id="data-table">
            <thead id="thead"></thead>
            <tbody id="tbody"></tbody>
        </table>
    </div>
</main>

<script>
    let modActual = 'pacientes';
    const token = localStorage.getItem('token');
    const user = JSON.parse(localStorage.getItem('user'));

    // Redirigir si no hay token al cargar
    if (!token) window.location.href = '/login';

    document.getElementById('user-info').innerText = `${user?.username} (${user?.rol})`;

    async function cargarDatos() {
        const errorDiv = document.getElementById('error-container');
        errorDiv.style.display = 'none';
        
        try {
            const res = await fetch(`/api/${modActual}`, {
                headers: { 'Authorization': `Bearer ${token}` }
            });

            // MANEJO DE ERRORES DE AUTENTICACIÓN
            if (res.status === 401) {
                alert("Sesión expirada. Por favor inicie sesión nuevamente.");
                logout();
                return;
            }

            if (res.status === 403) {
                errorDiv.innerText = "⚠️ No tienes permisos para ver este módulo.";
                errorDiv.style.display = 'block';
                document.getElementById('tbody').innerHTML = '';
                return;
            }

            const data = await res.json();
            renderizar(data);
        } catch (err) {
            console.error("Error de red:", err);
        }
    }

    function renderizar(data) {
        const tbody = document.getElementById('tbody');
        tbody.innerHTML = data.map(item => `
            <tr>
                <td>${item.nombre || item.numeroOrden || item._id}</td>
                <td>${item.pacienteId?.nombre || item.especialidad || 'N/A'}</td>
                <td><button onclick="alert('ID: ${item._id}')">Detalles</button></td>
            </tr>
        `).join('');
    }

    function switchModulo(m) {
        modActual = m;
        document.getElementById('page-title').innerText = m.toUpperCase();
        cargarDatos();
    }

    function logout() {
        localStorage.clear();
        window.location.href = '/login';
    }

    // Carga inicial
    cargarDatos();
</script>
</body>
</html>