<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LabSystem Pro | Gestión</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        :root { --primary: #0056b3; --accent: #00b4d8; --dark: #0f172a; --drawer-w: 400px; --sidebar-w: 260px; }
        body { font-family: 'Poppins', sans-serif; margin: 0; display: flex; height: 100vh; background: #f4f7fe; overflow: hidden; width: 100vw; }
        
        .sidebar { width: var(--sidebar-w); min-width: var(--sidebar-w); background: var(--dark); color: white; display: flex; flex-direction: column; padding: 20px; box-sizing: border-box; }
        .nav-item { padding: 14px; margin-bottom: 8px; border-radius: 12px; cursor: pointer; color: #94a3b8; display: flex; align-items: center; gap: 10px; }
        .nav-item.active { background: var(--primary); color: white; }

        /* CORRECCIÓN: Contenedor principal adaptable */
        .main-wrapper { flex: 1; min-width: 0; display: flex; flex-direction: column; transition: all 0.4s ease; background: #f4f7fe; }
        .main-wrapper.shrunk { margin-right: var(--drawer-w); }

        header { background: white; padding: 20px 40px; border-bottom: 5px solid var(--accent); display: flex; justify-content: space-between; align-items: center; }
        .content { padding: 30px; overflow-y: auto; flex-grow: 1; }
        .card { background: white; border-radius: 18px; padding: 25px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); overflow-x: auto; }
        
        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; padding: 12px; border-bottom: 2px solid #f1f5f9; color: #64748b; font-size: 0.8rem; }
        td { padding: 12px; border-bottom: 1px solid #f1f5f9; color: #1e293b; }

        .btn { border: none; padding: 10px 18px; border-radius: 8px; cursor: pointer; font-weight: 600; display: inline-flex; align-items: center; gap: 8px; }
        .btn-add { background: var(--primary); color: white; }
        .btn-list { background: #00b4d8; color: white; }
        .btn-edit { color: white; background: #28a745; margin-right: 5px; padding: 6px 10px; font-size: 0.8rem; }
        .btn-delete { color: white; background: #dc3545; padding: 6px 10px; font-size: 0.8rem; }

        /* CORRECCIÓN: Drawer con ancho fijo y scroll interno */
        .drawer { position: fixed; right: calc(-1 * var(--drawer-w)); top: 0; width: var(--drawer-w); height: 100%; background: white; transition: 0.4s; z-index: 2000; padding: 30px; box-shadow: -5px 0 20px rgba(0,0,0,0.1); box-sizing: border-box; overflow-y: auto; }
        .drawer.open { right: 0; }
        input { width: 100%; padding: 12px; margin-bottom: 15px; border: 1px solid #ddd; border-radius: 8px; box-sizing: border-box; }
        label { font-weight: 600; font-size: 0.9rem; display: block; margin-bottom: 5px; color: #444; }
    </style>
</head>
<body>

    <aside class="sidebar">
        <h2 style="color:var(--accent); text-align:center">LABPRO V4</h2>
        <nav id="nav-menu"></nav>
        <button onclick="logout()" class="btn" style="margin-top:auto; background:#334155; color:white; justify-content:center">SALIR</button>
    </aside>

    <div class="main-wrapper" id="main-container">
        <header>
            <h2 id="view-title">Bienvenido</h2>
            <div id="user-badge" style="font-weight:bold"></div>
        </header>
        <div class="content">
            <div id="action-bar" style="margin-bottom:20px; display:flex; gap:10px"></div>
            <div class="card">
                <table>
                    <thead><tr id="table-head"></tr></thead>
                    <tbody id="table-body"></tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="drawer" class="drawer">
        <h2 id="drawer-title" style="margin-top:0">Formulario</h2>
        <form id="crud-form">
            <input type="hidden" id="item-id">
            <div id="dynamic-fields"></div>
            <button type="submit" class="btn btn-add" style="width:100%; justify-content:center">GUARDAR CAMBIOS</button>
            <button type="button" onclick="toggleDrawer(false)" class="btn" style="width:100%; margin-top:10px; background:#f8f9fa; justify-content:center; border:1px solid #ddd">CANCELAR</button>
        </form>
    </div>

    <script>
        const user = JSON.parse(localStorage.getItem('user'));
        const token = localStorage.getItem('token');
        let currentEntity = '';

        if (!token) window.location.href = '/login';
        document.getElementById('user-badge').innerText = `${user.username} (${user.rol})`;

        const PERMISOS = {
            'Admin': ['pacientes', 'medicos', 'examenes', 'resultados', 'insumos', 'facturas', 'usuarios'],
            'Recepcion': ['pacientes', 'citas'],
            'Bioanalista': ['examenes', 'resultados', 'pacientes'],
            'Contador': ['facturas', 'insumos']
        };

        const MODEL_MAP = {
            pacientes: [{n:'nombre', l:'Nombre'}, {n:'ci', l:'Cédula'}],
            medicos: [{n:'nombre', l:'Nombre'}, {n:'especialidad', l:'Especialidad'}],
            examenes: [{n:'nombre', l:'Examen'}, {n:'precio', l:'Precio'}],
            usuarios: [{n:'username', l:'Usuario'}, {n:'rol', l:'Rol'}],
            insumos: [{n:'nombre', l:'Nombre'}, {n:'stock', l:'Stock'}],
            facturas: [{n:'montoTotal', l:'Total'}, {n:'metodoPago', l:'Pago'}],
            resultados: [{n:'numeroOrden', l:'Orden'}, {n:'valor', l:'Valor'}]
        };

        const nav = document.getElementById('nav-menu');
        (PERMISOS[user.rol] || []).forEach(m => {
            nav.innerHTML += `<div class="nav-item" id="nav-${m}" onclick="loadData('${m}', this)"><i class="fas fa-folder"></i> ${m.toUpperCase()}</div>`;
        });

        async function loadData(entity, el) {
            currentEntity = entity;
            document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
            if(el) el.classList.add('active');
            
            document.getElementById('view-title').innerText = `Gestión: ${entity.toUpperCase()}`;
            document.getElementById('action-bar').innerHTML = `
                <button class="btn btn-add" onclick="openForm()"><i class="fas fa-plus"></i> NUEVO</button>
                <button class="btn btn-list" onclick="loadData('${entity}')"><i class="fas fa-sync"></i> LISTAR</button>
            `;
            
            try {
                const res = await fetch(`/api/${entity}`, { headers: {'Authorization': `Bearer ${token}`} });
                const data = await res.json();
                renderTable(data);
            } catch (err) { console.error(err); }
        }

        function renderTable(data) {
            const head = document.getElementById('table-head');
            const body = document.getElementById('table-body');
            const fields = MODEL_MAP[currentEntity] || [{n:'nombre', l:'Dato'}];

            head.innerHTML = fields.map(f => `<th>${f.l}</th>`).join('') + '<th style="text-align:right">ACCIONES</th>';
            body.innerHTML = '';

            if (!data || data.length === 0) {
                body.innerHTML = `<tr><td colspan="${fields.length + 1}" style="text-align:center; padding:20px">No hay registros.</td></tr>`;
                return;
            }

            data.forEach(item => {
                let rows = fields.map(f => `<td>${item[f.n] || '---'}</td>`).join('');
                body.innerHTML += `<tr>${rows}<td style="text-align:right">
                    <button class="btn btn-edit" onclick="openForm('${item._id}')"><i class="fas fa-edit"></i> EDITAR</button>
                    <button class="btn btn-delete" onclick="deleteItem('${item._id}')"><i class="fas fa-trash"></i> BORRAR</button>
                </td></tr>`;
            });
        }

        async function openForm(id = null) {
            document.getElementById('item-id').value = id || '';
            const fields = document.getElementById('dynamic-fields');
            fields.innerHTML = 'Cargando...';

            let val = {};
            if(id) {
                const res = await fetch(`/api/${currentEntity}/${id}`, { headers: {'Authorization': `Bearer ${token}`} });
                val = await res.json();
            }

            fields.innerHTML = (MODEL_MAP[currentEntity] || []).map(f => `
                <label>${f.l}</label>
                <input name="${f.n}" value="${val[f.n] || ''}" required>
            `).join('');

            toggleDrawer(true);
        }

        document.getElementById('crud-form').onsubmit = async (e) => {
            e.preventDefault();
            const payload = Object.fromEntries(new FormData(e.target));
            const id = document.getElementById('item-id').value;
            const method = id ? 'PUT' : 'POST';
            const url = id ? `/api/${currentEntity}/${id}` : `/api/${currentEntity}`;

            const res = await fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify(payload)
            });

            if(res.ok) {
                Swal.fire('Guardado', 'Datos actualizados', 'success');
                toggleDrawer(false);
                loadData(currentEntity);
            }
        };

        async function deleteItem(id) {
            Swal.fire({ title: '¿Borrar?', icon: 'warning', showCancelButton: true }).then(async (r) => {
                if (r.isConfirmed) {
                    await fetch(`/api/${currentEntity}/${id}`, { method: 'DELETE', headers: {'Authorization': `Bearer ${token}`} });
                    loadData(currentEntity);
                }
            });
        }

        function toggleDrawer(s) { 
            document.getElementById('drawer').classList.toggle('open', s); 
            document.getElementById('main-container').classList.toggle('shrunk', s); 
        }
        function logout() { localStorage.clear(); window.location.href = '/login'; }
        
        const mods = PERMISOS[user.rol] || [];
        if(mods.length > 0) loadData(mods[0], document.getElementById(`nav-${mods[0]}`));
    </script>
</body>
</html>