###  pason 1 Configuración de Variables
@baseUrl = http://localhost:3000
@token = {{login.response.body.token}}

# ==========================================
# 1. AUTENTICACIÓN (LOGIN)
# ==========================================

# @name login
POST {{baseUrl}}/auth
Content-Type: application/json

{
  "username": "admin",
  "password": "123"
}

### Paso n2

### VARIABLES GLOBALES
@url = http://localhost:3000
@token = TU_TOKEN_AQUI_DESPUES_DE_LOGIN

### 1. PRUEBA DE LOGIN (FUERZA BRUTA)
# Intenta con credenciales falsas 5 veces y observa el bloqueo en la UI
POST {{url}}/auth
Content-Type: application/json

{
    "username": "admin",
    "password": "clave_incorrecta"
}

### 2. OBTENER PACIENTES (TODOS LOS ROLES)
GET {{url}}/api/pacientes
Authorization: Bearer {{token}}

### 3. CREAR UN INSUMO (PROBAR ALERTA DE STOCK BAJO)
# Crea un insumo con stock < 10 para ver la fila roja en el frontend
POST {{url}}/api/insumos
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "nombre": "Reactivo de Prueba Crítico",
    "stock": 5,
    "unidad": "ML",
    "fechaVencimiento": "2026-12-31"
}

### 4. PRUEBA DE SEGURIDAD: ACCESO A FACTURAS
# Si el token es de un "Bioanalista", esto debe devolver 403 Forbidden
GET {{url}}/api/facturas
Authorization: Bearer {{token}}

### 5. CREAR UNA CITA (RELACIONALIDAD)
# Sustituye el pacienteId por un ID real de tu base de datos
POST {{url}}/api/citas
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "pacienteId": "65f123abc456def789012345",
    "fecha": "2026-04-15T09:00:00",
    "motivo": "Examen de Sangre",
    "estado": "Pendiente"
}

### 6. ACTUALIZAR EQUIPO (SOLO ADMIN)
PUT {{url}}/api/equipos/ID_DEL_EQUIPO
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "estado": "En Reparacion"
}