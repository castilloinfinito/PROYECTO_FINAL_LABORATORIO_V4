###############################################################################
# PROTOCOLO DE PRUEBAS TÉCNICAS - LABSYSTEM PRO 2026
# Extension: REST Client (Visual Studio Code)
###############################################################################

@url = http://localhost:3000

### 0. AUTENTICACIÓN (LOGIN)
# @name login
POST {{url}}/auth
Content-Type: application/json

{
    "username": "admin",
    "password": "123"
}

### EXTRACCIÓN DINÁMICA DEL TOKEN
@token = {{login.response.body.token}}

###############################################################################
### 1. ENTIDAD: PACIENTES
###############################################################################

### 1.1 Listar Pacientes
GET {{url}}/api/pacientes
Authorization: Bearer {{token}}

### 1.2 Crear Paciente (Cambiar CI para evitar duplicados)
# @name nuevoPaciente
POST {{url}}/api/pacientes
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "nombre": "Carlos Alberto",
    "ci": "V-20555666",
    "telefono": "0424-1112233"
}

### 1.3 Eliminar Paciente (Sustituir ID_PACIENTE)
DELETE {{url}}/api/pacientes/ID_AQUI
Authorization: Bearer {{token}}

###############################################################################
### 2. ENTIDAD: MÉDICOS
###############################################################################

### 2.1 Listar Médicos
GET {{url}}/api/medicos
Authorization: Bearer {{token}}

### 2.2 Crear Médico
POST {{url}}/api/medicos
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "nombre": "Dra. Elena Rivas",
    "especialidad": "Hematología",
    "mpps": "123456"
}

### 2.3 Actualizar Médico (Sustituir ID_MEDICO)
PUT {{url}}/api/medicos/ID_AQUI
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "especialidad": "Inmunología Clínica"
}

###############################################################################
### 3. ENTIDAD: INSUMOS (CON ALERTA DE STOCK)
###############################################################################

### 3.1 Listar Insumos
GET {{url}}/api/insumos
Authorization: Bearer {{token}}

### 3.2 Crear Insumo (Stock < 10 para probar alerta roja)
POST {{url}}/api/insumos
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "nombre": "Reactivo de Glucosa",
    "stock": 4,
    "unidad": "ML",
    "fechaVencimiento": "2027-01-01"
}

### 3.3 Actualizar Stock (Reposición)
PUT {{url}}/api/insumos/ID_AQUI
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "stock": 50
}

###############################################################################
### 4. ENTIDAD: CITAS (RELACIONAL)
###############################################################################

### 4.1 Listar Citas (Verificar Populate de Paciente)
GET {{url}}/api/citas
Authorization: Bearer {{token}}

### 4.2 Crear Cita (Requiere ID de un Paciente real)
POST {{url}}/api/citas
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "pacienteId": "PONER_ID_PACIENTE_AQUI",
    "fecha": "2026-06-15T08:30:00Z",
    "motivo": "Perfil 20",
    "estado": "Pendiente"
}

### 4.3 Cancelar Cita
PUT {{url}}/api/citas/ID_AQUI
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "estado": "Cancelada"
}

###############################################################################
### 5. ENTIDAD: FACTURAS (ADMIN/CONTADOR)
###############################################################################

### 5.1 Listar Facturas
GET {{url}}/api/facturas
Authorization: Bearer {{token}}

### 5.2 Crear Factura
POST {{url}}/api/facturas
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "pacienteId": "PONER_ID_PACIENTE_AQUI",
    "montoTotal": 240.50,
    "metodoPago": "Transferencia",
    "pagado": false
}

### 5.3 Registrar Pago
PUT {{url}}/api/facturas/ID_AQUI
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "pagado": true
}

###############################################################################
### 6. ENTIDAD: EQUIPOS
###############################################################################

### 6.1 Listar Equipos
GET {{url}}/api/equipos
Authorization: Bearer {{token}}

### 6.2 Crear Equipo
POST {{url}}/api/equipos
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "nombre": "Analizador Químico A-100",
    "marca": "Roche",
    "estado": "Operativo"
}

### 6.3 Cambiar Estado a Mantenimiento
PUT {{url}}/api/equipos/ID_AQUI
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "estado": "En Reparacion"
}

###############################################################################
### 7. ENTIDAD: EXÁMENES
###############################################################################

### 7.1 Listar Exámenes
GET {{url}}/api/examenes
Authorization: Bearer {{token}}

### 7.2 Crear Examen
POST {{url}}/api/examenes
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "nombre": "Urocultivo",
    "precio": 45.00,
    "numeroOrden": "ORD-001"
}

### 7.3 Eliminar Examen
DELETE {{url}}/api/examenes/ID_AQUI
Authorization: Bearer {{token}}

###############################################################################
### 8. ENTIDAD: RESULTADOS (SENSIBLE)
###############################################################################

### 8.1 Listar Resultados
GET {{url}}/api/resultados
Authorization: Bearer {{token}}

### 8.2 Crear Resultado (Requiere IDs reales)
POST {{url}}/api/resultados
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "pacienteId": "ID_PACIENTE",
    "medicoId": "ID_MEDICO",
    "valor": "Hemoglobina 14.2 g/dL",
    "numeroOrden": "ORD-001"
}

### 8.3 Modificar Resultado
PUT {{url}}/api/resultados/ID_AQUI
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "valor": "Hemoglobina 13.9 g/dL (Corregido)"
}

###############################################################################
### 9. ENTIDAD: USUARIOS (ADMIN SOLAMENTE)
###############################################################################

### 9.1 Listar Usuarios
GET {{url}}/api/usuarios
Authorization: Bearer {{token}}

### 9.2 Crear Nuevo Usuario (Bioanalista)
POST {{url}}/api/usuarios
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "username": "bio_pedro",
    "password": "bio123password",
    "rol": "Bioanalista",
    "cargo": "Jefe de Laboratorio"
}

### 9.3 Eliminar Usuario
DELETE {{url}}/api/usuarios/ID_AQUI
Authorization: Bearer {{token}}

